# ----- Postgres -----
POSTGRES_USER=pharma
POSTGRES_PASSWORD=pharma_dev_password
POSTGRES_DB=pharma_connect
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- Backend -----
# SQLAlchemy URL is built from the values above when running in Docker.
# Override DATABASE_URL only if you run the backend outside Docker.
DATABASE_URL=postgresql+psycopg://pharma:pharma_dev_password@db:5432/pharma_connect

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins for the frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SMTP) - leave blank in dev to log emails to stdout instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@pharma-connect.local
SMTP_TLS=true

# Claude API (chatbot). Leave blank to disable the chatbot feature.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
CHATBOT_DAILY_REQUEST_LIMIT=50

# ----- Frontend -----
VITE_API_BASE_URL=http://localhost:8000
